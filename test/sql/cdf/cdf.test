# name: test/sql/cdf/cdf.test
# description: test cdf extension
# group: [cdf]

require cdf

statement ok
CREATE TABLE t(id INT, v VARCHAR);

statement ok
PRAGMA enable_cdf('t');

query I
INSERT INTO t VALUES (1, 'hello') RETURNING id;
----
1

query I
INSERT INTO t VALUES (2, 'world');
----
1

query III
SELECT _change_type, id, v FROM __duckdb_cdf_t_log ORDER BY id;
----
insert	1	hello
insert	2	world
