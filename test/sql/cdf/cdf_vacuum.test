# name: test/sql/cdf/cdf_vacuum.test
# description: test cdf extension with vacuum
# group: [cdf]

require cdf

statement ok
CREATE TABLE t(id INT, v VARCHAR);

statement ok
PRAGMA enable_cdf('t');

statement ok
INSERT INTO t VALUES (1, 'hello');

statement ok
INSERT INTO t VALUES (2, 'world');

statement ok
PRAGMA vacuum_cdf('t', '0 seconds');

query I
SELECT count(*) FROM read_cdf('t');
----
0
