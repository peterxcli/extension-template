# name: test/sql/cdf/cdf_bug.test
# description: test cdf extension with insert and delete union bug
# group: [cdf]

require cdf

statement ok
CREATE TABLE t(id INT, v VARCHAR);

statement ok
PRAGMA enable_cdf('t');

statement ok
INSERT INTO t VALUES (1, 'hello');

statement ok
INSERT INTO t VALUES (2, 'world');

statement ok
DELETE FROM t WHERE id = 1;

query III
SELECT _change_type, id, v FROM read_cdf('t') ORDER BY id, _change_type;
----
delete	1	hello
insert	1	hello
insert	2	world
